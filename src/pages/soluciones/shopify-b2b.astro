---
import LandingLayout from '../../layouts/LandingLayout.astro';
import HeroLight from '../../components/sections/HeroLight.astro';
import ShortAnswer from '../../components/aeo/ShortAnswer.astro';
import ForWhomTable from '../../components/aeo/ForWhomTable.astro';
import ComparisonTable from '../../components/aeo/ComparisonTable.astro';
import Methodology from '../../components/aeo/Methodology.astro';
import FAQAccordion from '../../components/aeo/FAQAccordion.astro';
import ContactBlock from '../../components/sections/ContactBlock.astro';
import { organization } from '../../data/structured-data';

const breadcrumbs = [
  { label: 'Soluciones' },
  { label: 'Shopify B2B' },
];

const faqs = [
  { question: '¿Shopify permite venta B2B nativa?', answer: 'Sí. Desde 2022, Shopify Plus incluye funcionalidades B2B nativas: catálogos privados por empresa, precios personalizados, condiciones de pago NET 30/60/90, pedidos rápidos, representantes comerciales y la posibilidad de gestionar B2B y B2C desde una sola tienda sin apps externas.' },
  { question: '¿Necesito Shopify Plus para B2B?', answer: 'Las funcionalidades B2B nativas de Shopify solo están disponibles en Shopify Plus. En planes estándar se pueden simular algunos escenarios B2B con apps de terceros, pero para catálogos privados, precios por empresa y condiciones de pago profesionales, Shopify Plus es la opción recomendada.' },
  { question: '¿Se puede integrar Shopify B2B con un ERP?', answer: 'Sí, y es lo más habitual. La integración ERP-Shopify sincroniza catálogos de productos con precios diferenciados, stock, clientes empresa, pedidos y facturación. Es fundamental para que la operación B2B sea escalable y no dependa de entrada manual de datos.' },
  { question: '¿Shopify B2B permite precios diferentes por cliente?', answer: 'Sí. Shopify Plus B2B permite crear catálogos de precios específicos por empresa o grupo de empresas, con descuentos por volumen, precios personalizados por producto y condiciones de pago diferenciadas. Todo se gestiona desde el panel de Shopify sin necesidad de apps externas.' },
  { question: '¿Cuánto cuesta implementar Shopify B2B?', answer: 'Una implementación B2B sobre Shopify Plus suele costar entre 25.000 € y 70.000 €, dependiendo de la complejidad del catálogo, las integraciones con ERP, la personalización del portal de compra y la necesidad de flujos especiales como aprobación de pedidos o pedidos recurrentes.' },
];

const serviceSchema = {
  '@type': 'Service',
  name: 'Shopify B2B',
  provider: organization,
  description: 'Implementación de venta B2B sobre Shopify Plus: catálogos privados, precios segmentados, integración ERP y operaciones mayoristas.',
  areaServed: { '@type': 'Country', name: 'España' },
  serviceType: 'B2B eCommerce Implementation',
};

const faqSchema = {
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<LandingLayout
  title="Shopify B2B — Venta Mayorista y Catálogos"
  description="Shopify B2B con catálogos privados, precios por empresa, NET 30/60/90 e integración ERP sobre Shopify Plus."
  ogTitle="Shopify B2B — Venta Mayorista Profesional"
  ogDescription="Catálogos privados, precios segmentados, pedidos automatizados e integración ERP sobre Shopify Plus. Digitaliza tu venta mayorista."
  ogImage="https://agencia-shopify.com/og/shopify-b2b.png"
  keywords="shopify b2b, venta mayorista shopify, shopify plus b2b, catálogos privados shopify, precios por empresa shopify, integración erp shopify b2b"
  breadcrumbs={breadcrumbs}
  jsonLd={[organization, serviceSchema, faqSchema]}
>
  <HeroLight
    badge="Shopify B2B"
    title="Venta mayorista en Shopify con catálogos privados, precios por empresa e integración ERP."
    subtitle="Implementamos operaciones B2B sobre Shopify Plus: catálogos segmentados, condiciones de pago profesionales, pedidos automatizados y conexión con tu ERP para que la operación escale sin fricción."
    ctaPrimary={{ label: 'Consultar proyecto B2B', href: '#contacto' }}
  />

  <ShortAnswer
    text="Shopify B2B permite a fabricantes, distribuidores y mayoristas gestionar venta profesional desde Shopify Plus: catálogos privados con precios por empresa, condiciones de pago NET 30/60/90, representantes comerciales, pedidos rápidos y la capacidad de combinar B2B y B2C en una sola tienda. eComm360 implementa estas operaciones integrando Shopify con el ERP del cliente para sincronizar catálogos, stock, pedidos y facturación de forma automatizada."
  />

  <section id="definicion" class="bg-white py-16 md:py-20">
    <div class="container">
      <div class="max-w-3xl">
        <h2 class="text-3xl font-extrabold tracking-[-0.06em] text-[#111714] md:text-4xl">
          Qué resuelve Shopify B2B
        </h2>
        <div class="mt-6 space-y-4 text-lg leading-8 text-[#617069]">
          <p>
            Muchos fabricantes y distribuidores gestionan su venta mayorista con hojas de Excel, emails y llamadas telefónicas. <strong class="text-[#111714]">Shopify B2B digitaliza todo ese proceso</strong> en una plataforma donde tus clientes profesionales pueden consultar catálogos, ver sus precios, hacer pedidos y repetir compras de forma autónoma. La <a href="https://www.shopify.com/plus/solutions/b2b-ecommerce" target="_blank" rel="noopener" class="font-medium text-[#376A21] underline decoration-[#376A21]/30 hover:decoration-[#376A21]">solución B2B oficial de Shopify</a> incluye estas funcionalidades de forma nativa.
          </p>
          <p>
            Lo que hace especial a Shopify B2B es que funciona sobre <a href="/shopify/plus/" class="font-medium text-[#376A21] underline decoration-[#376A21]/30 hover:decoration-[#376A21]">Shopify Plus</a>, lo que significa que puedes gestionar B2B y B2C desde la misma plataforma. Y con una <a href="/integracion-shopify/erp-shopify/" class="font-medium text-[#376A21] underline decoration-[#376A21]/30 hover:decoration-[#376A21]">integración con tu ERP</a>, los catálogos, el stock y los pedidos se sincronizan automáticamente.
          </p>
        </div>
      </div>
    </div>
  </section>

  <ForWhomTable
    suitable={[
      'Fabricantes que venden a distribuidores y minoristas con catálogos y precios diferenciados.',
      'Distribuidores que necesitan un portal de pedidos online para sus clientes profesionales.',
      'Empresas que combinan venta B2B y B2C y quieren gestionar ambas desde una sola plataforma.',
      'Negocios con ERP que necesitan sincronizar catálogos, stock y pedidos con la tienda online.',
      'Empresas que quieren ofrecer a sus clientes B2B una experiencia de compra moderna y autónoma.',
    ]}
    notSuitable={[
      'Negocios que solo venden al consumidor final sin canal mayorista.',
      'Empresas con operaciones B2B muy simples que no justifican Shopify Plus.',
      'Negocios donde la venta mayorista se gestiona exclusivamente a través de representantes presenciales.',
    ]}
  />

  <ComparisonTable
    title="Shopify B2B nativo vs apps de terceros"
    thisLabel="B2B nativo (Shopify Plus)"
    otherLabel="Apps de terceros"
    items={[
      { label: 'Catálogos privados', thisOption: 'Integrado: por empresa, con precios individuales', otherOption: 'Variable según app, limitaciones frecuentes' },
      { label: 'Precios por empresa', thisOption: 'Nativo: listas de precios, descuentos por volumen', otherOption: 'Depende de la app, puede haber conflictos' },
      { label: 'Condiciones de pago', thisOption: 'NET 30/60/90 nativo, sin fricciones', otherOption: 'Requiere configuración adicional' },
      { label: 'Rendimiento', thisOption: 'Sin impacto: es parte de la plataforma', otherOption: 'Puede afectar velocidad y checkout' },
      { label: 'Mantenimiento', thisOption: 'Shopify lo mantiene y actualiza', otherOption: 'Depende del desarrollador de la app' },
    ]}
  />

  <Methodology
    title="Cómo implementamos Shopify B2B"
    steps={[
      { step: '01', title: 'Análisis comercial', text: 'Mapeamos tu operación B2B: tipos de cliente, catálogos, políticas de precios, condiciones de pago y flujos de pedido.' },
      { step: '02', title: 'Arquitectura B2B', text: 'Diseñamos la estructura de catálogos, listas de precios, roles de usuario y reglas de negocio sobre Shopify Plus.' },
      { step: '03', title: 'Integración ERP', text: 'Conectamos Shopify con tu ERP para sincronizar catálogos, precios, stock, clientes, pedidos y facturación.' },
      { step: '04', title: 'Portal y experiencia', text: 'Desarrollamos el portal de compra B2B con diseño profesional, pedidos rápidos y funcionalidades de autoservicio.' },
    ]}
  />

  <FAQAccordion items={faqs} />

  <ContactBlock
    title="¿Quieres digitalizar tu venta mayorista con Shopify?"
    subtitle="Te ayudamos a diseñar e implementar una operación B2B sobre Shopify Plus integrada con tu ERP."
    ctaPrimary={{ label: 'Consultar proyecto B2B', href: '#contacto' }}
  />
</LandingLayout>
