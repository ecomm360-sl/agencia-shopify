---
import LandingLayout from '../../layouts/LandingLayout.astro';
import HeroLight from '../../components/sections/HeroLight.astro';
import ShortAnswer from '../../components/aeo/ShortAnswer.astro';
import ForWhomTable from '../../components/aeo/ForWhomTable.astro';
import ComparisonTable from '../../components/aeo/ComparisonTable.astro';
import Methodology from '../../components/aeo/Methodology.astro';
import FAQAccordion from '../../components/aeo/FAQAccordion.astro';
import ContactBlock from '../../components/sections/ContactBlock.astro';
import { organization } from '../../data/structured-data';

const breadcrumbs = [
  { label: 'Migración a Shopify', href: '/migracion-shopify/' },
  { label: 'PrestaShop a Shopify' },
];

const faqs = [
  { question: '¿Cuánto tarda migrar de PrestaShop a Shopify?', answer: 'Una migración típica de PrestaShop a Shopify tarda entre 8 y 14 semanas, dependiendo del tamaño del catálogo, la complejidad de las reglas comerciales (descuentos, precios especiales, grupos de clientes), las integraciones existentes y la necesidad de preservar el posicionamiento SEO.' },
  { question: '¿Se pueden migrar los módulos de PrestaShop a Shopify?', answer: 'Los módulos de PrestaShop no se migran directamente a Shopify porque son tecnologías diferentes. Lo que hacemos es analizar qué funcionalidad aporta cada módulo y buscar el equivalente en el ecosistema de Shopify: apps nativas, funcionalidades built-in de Shopify, o desarrollo a medida cuando no existe una alternativa directa.' },
  { question: '¿Se pierden los clientes y pedidos históricos?', answer: 'No. Migramos clientes con sus datos de contacto e historiales de pedido, y pedidos históricos con toda su información. Los clientes pueden seguir accediendo a su cuenta con el mismo email (requieren restablecer contraseña por razones de seguridad, ya que las contraseñas hasheadas de PrestaShop no son compatibles con Shopify).' },
  { question: '¿El SEO se ve afectado al migrar de PrestaShop a Shopify?', answer: 'Puede verse afectado si la migración no se planifica correctamente. La estructura de URLs de Shopify es diferente a la de PrestaShop, por lo que es imprescindible un mapa completo de redirecciones 301, preservación de metadatos y monitorización post-migración. Con un plan de migración SEO adecuado, el impacto es temporal y recuperable en 4-8 semanas.' },
  { question: '¿Cuánto cuesta migrar de PrestaShop a Shopify?', answer: 'El coste parte de 8.000-12.000 € para migraciones de catálogos pequeños-medianos. Para catálogos grandes con reglas comerciales complejas, integraciones con ERP y preservación SEO avanzada, el rango es de 15.000-35.000 €. La complejidad de las reglas de negocio de PrestaShop (descuentos, grupos, precios específicos) es el factor que más influye en el coste.' },
];

const serviceSchema = {
  '@type': 'Service',
  name: 'Migración de PrestaShop a Shopify',
  provider: organization,
  description: 'Migración profesional de PrestaShop a Shopify: transferencia de catálogo, clientes, pedidos, preservación SEO e integraciones.',
  areaServed: { '@type': 'Country', name: 'España' },
  serviceType: 'eCommerce Platform Migration',
};

const faqSchema = {
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<LandingLayout
  title="Migrar de PrestaShop a Shopify — Sin Perder Datos ni Clientes"
  description="Migración de PrestaShop a Shopify: catálogo completo, clientes, pedidos y preservación SEO. Elimina dependencia de módulos. Desde 8.000 €. Consulta gratuita."
  ogTitle="De PrestaShop a Shopify — Simplifica tu Operativa"
  ogDescription="Migramos tu tienda de PrestaShop a Shopify: productos, clientes, historial y SEO. Proceso profesional con validación completa de datos."
  ogImage="https://agencia-shopify.com/og/prestashop-a-shopify.png"
  keywords="migrar prestashop a shopify, prestashop a shopify, migración prestashop, prestashop vs shopify, cambiar de prestashop a shopify, dejar prestashop"
  breadcrumbs={breadcrumbs}
  jsonLd={[organization, serviceSchema, faqSchema]}
>
  <HeroLight
    badge="PrestaShop a Shopify"
    title="Migra de PrestaShop a Shopify sin perder datos, clientes ni posicionamiento."
    subtitle="Transferimos tu catálogo completo, clientes, pedidos e historial desde PrestaShop a Shopify con un proceso que prioriza la continuidad de tu negocio."
    ctaPrimary={{ label: 'Consultar migración', href: '#contacto' }}
  />

  <ShortAnswer
    text="Migrar de PrestaShop a Shopify implica transferir el catálogo de productos con todas sus variantes y atributos, clientes con historiales de pedido, reglas comerciales y contenido, preservando el posicionamiento SEO mediante redirecciones 301. eComm360 gestiona estas migraciones con una metodología que elimina la dependencia de módulos de PrestaShop, simplifica la operativa y prepara el negocio para escalar sobre una plataforma más robusta y con mejor ecosistema."
  />

  <section id="definicion" class="bg-white py-16 md:py-20">
    <div class="container">
      <div class="max-w-3xl">
        <h2 class="text-3xl font-extrabold tracking-[-0.06em] text-[#111714] md:text-4xl">
          Por qué migrar de PrestaShop a Shopify
        </h2>
        <div class="mt-6 space-y-4 text-lg leading-8 text-[#617069]">
          <p>
            PrestaShop es una plataforma que funciona, pero que <strong class="text-[#111714]">genera dependencias técnicas que no escalan bien</strong>: módulos que se quedan sin soporte, actualizaciones que rompen funcionalidades, y una operativa diaria que requiere más atención técnica de la que debería.
          </p>
          <p>
            Shopify resuelve la mayoría de estas fricciones: hosting gestionado, actualizaciones automáticas, un ecosistema de apps mucho más amplio y una plataforma que mejora continuamente sin que tu equipo tenga que preocuparse por la infraestructura.
          </p>
          <p>
            La migración no es solo mover datos: es la oportunidad de <strong class="text-[#111714]">simplificar tu operativa y preparar el negocio para crecer</strong> con menos dependencia técnica.
          </p>
        </div>
      </div>
    </div>
  </section>

  <ForWhomTable
    suitable={[
      'Tiendas PrestaShop con problemas de rendimiento, actualizaciones pendientes o módulos sin soporte.',
      'Negocios que dedican demasiado tiempo a mantenimiento técnico en lugar de a vender.',
      'Empresas que han crecido y necesitan una plataforma más escalable y con mejor ecosistema.',
      'Tiendas que quieren aprovechar las funcionalidades nativas de Shopify (B2B, checkout, Flow).',
    ]}
    notSuitable={[
      'Tiendas PrestaShop que funcionan bien y no tienen problemas de escalabilidad ni mantenimiento.',
      'Negocios con módulos muy específicos de PrestaShop que no tienen equivalente en Shopify.',
      'Proyectos sin presupuesto para una migración profesional (riesgo de pérdida de datos o SEO).',
    ]}
  />

  <ComparisonTable
    title="PrestaShop vs Shopify"
    thisLabel="Shopify"
    otherLabel="PrestaShop"
    items={[
      { label: 'Hosting', thisOption: 'Gestionado por Shopify, sin preocupaciones', otherOption: 'Propio o contratado, requiere mantenimiento' },
      { label: 'Actualizaciones', thisOption: 'Automáticas, sin riesgo de rotura', otherOption: 'Manuales, pueden romper módulos' },
      { label: 'Ecosistema de apps', thisOption: '+8.000 apps verificadas', otherOption: 'Módulos variados, calidad desigual' },
      { label: 'Rendimiento', thisOption: 'CDN global incluido, optimizado', otherOption: 'Depende del hosting y configuración' },
      { label: 'B2B nativo', thisOption: 'Disponible en Shopify Plus', otherOption: 'Requiere módulos de terceros' },
      { label: 'Coste de mantenimiento', thisOption: 'Incluido en la suscripción', otherOption: 'Hosting + actualizaciones + parches' },
    ]}
  />

  <Methodology
    title="Cómo migramos de PrestaShop a Shopify"
    steps={[
      { step: '01', title: 'Auditoría PrestaShop', text: 'Analizamos tu instalación: catálogo, módulos instalados, reglas comerciales, integraciones y estructura SEO actual.' },
      { step: '02', title: 'Plan de migración', text: 'Definimos el mapa de datos, las equivalencias de funcionalidades (módulos → apps/nativo), el plan de redirecciones y la estrategia SEO.' },
      { step: '03', title: 'Migración y desarrollo', text: 'Transferimos datos, desarrollamos la nueva tienda en Shopify y configuramos las integraciones necesarias.' },
      { step: '04', title: 'QA y lanzamiento', text: 'Validamos datos migrados, testamos flujos de compra, activamos redirecciones y lanzamos con monitorización activa.' },
    ]}
  />

  <FAQAccordion items={faqs} />

  <ContactBlock
    title="¿Estás pensando en dejar PrestaShop?"
    subtitle="Analizamos tu tienda PrestaShop y te proponemos un plan de migración a Shopify realista y sin sorpresas."
    ctaPrimary={{ label: 'Consultar migración', href: '#contacto' }}
  />
</LandingLayout>
