---
import LandingLayout from '../../layouts/LandingLayout.astro';
import HeroLight from '../../components/sections/HeroLight.astro';
import ShortAnswer from '../../components/aeo/ShortAnswer.astro';
import ForWhomTable from '../../components/aeo/ForWhomTable.astro';
import Methodology from '../../components/aeo/Methodology.astro';
import FAQAccordion from '../../components/aeo/FAQAccordion.astro';
import ContactBlock from '../../components/sections/ContactBlock.astro';
import { organization } from '../../data/structured-data';

const breadcrumbs = [
  { label: 'Migración a Shopify', href: '/migracion-shopify/' },
  { label: 'LogiCommerce a Shopify' },
];

const faqs = [
  { question: '¿Cuánto tarda migrar de LogiCommerce a Shopify?', answer: 'Una migración de LogiCommerce a Shopify suele tardar entre 8 y 14 semanas. LogiCommerce tiene un modelo de datos específico que requiere un mapeo cuidadoso para transferir productos, clientes y pedidos a la estructura de Shopify. La complejidad depende del tamaño del catálogo y las integraciones existentes.' },
  { question: '¿Por qué migrar de LogiCommerce a Shopify?', answer: 'Las razones principales son: un ecosistema de apps y partners mucho más amplio, mayor flexibilidad para personalizar la tienda, acceso a funcionalidades como B2B nativo (en Plus), checkout optimizado con Shop Pay, y una comunidad de desarrollo global que garantiza evolución continua de la plataforma.' },
  { question: '¿Se pueden migrar todos los datos de LogiCommerce a Shopify?', answer: 'Se migran productos (con variantes, imágenes y atributos), clientes, pedidos históricos y contenido de páginas. Algunas funcionalidades específicas de LogiCommerce pueden requerir adaptación o uso de apps equivalentes en Shopify. El mapeo de datos se define en la fase de auditoría para asegurar que no se pierde información crítica.' },
  { question: '¿Cuánto cuesta migrar de LogiCommerce a Shopify?', answer: 'El coste de migración desde LogiCommerce parte de 10.000-15.000 € para catálogos medianos y puede llegar a 25.000-40.000 € para operaciones complejas con integraciones ERP, preservación SEO avanzada y funcionalidades B2B. El factor principal de coste es la complejidad del mapeo de datos y las integraciones.' },
];

const serviceSchema = {
  '@type': 'Service',
  name: 'Migración de LogiCommerce a Shopify',
  provider: organization,
  description: 'Migración profesional de LogiCommerce a Shopify: transferencia de catálogo, clientes, pedidos, preservación SEO e integraciones.',
  areaServed: { '@type': 'Country', name: 'España' },
  serviceType: 'eCommerce Platform Migration',
};

const faqSchema = {
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<LandingLayout
  title="LogiCommerce a Shopify — Migración Segura"
  description="Migración de LogiCommerce a Shopify: catálogo, clientes y pedidos con preservación SEO. Gana acceso a +8.000 apps y B2B nativo. Consulta sin compromiso."
  ogTitle="De LogiCommerce a Shopify — Gana Ecosistema"
  ogDescription="Migramos tu tienda de LogiCommerce a Shopify: más apps, más flexibilidad, B2B nativo y un ecosistema global de partners."
  ogImage="https://agencia-shopify.com/og/logicommerce-a-shopify.png"
  keywords="migrar logicommerce a shopify, logicommerce a shopify, migración logicommerce, logicommerce vs shopify, alternativa logicommerce"
  breadcrumbs={breadcrumbs}
  jsonLd={[organization, serviceSchema, faqSchema]}
>
  <HeroLight
    badge="LogiCommerce a Shopify"
    title="Migra de LogiCommerce a Shopify y gana ecosistema, flexibilidad y crecimiento."
    subtitle="Transferimos tu catálogo, clientes y operativa desde LogiCommerce a Shopify con un proceso consultivo que prioriza la continuidad del negocio."
    ctaPrimary={{ label: 'Consultar migración', href: '#contacto' }}
  />

  <ShortAnswer
    text="Migrar de LogiCommerce a Shopify permite a las empresas acceder a un ecosistema de apps y partners significativamente más amplio, funcionalidades como B2B nativo y checkout optimizado con Shop Pay, y una plataforma con evolución continua respaldada por una comunidad global de desarrollo. eComm360 gestiona estas migraciones con un enfoque consultivo que incluye mapeo detallado de datos, preservación del SEO y configuración de integraciones post-migración."
  />

  <section id="definicion" class="bg-white py-16 md:py-20">
    <div class="container">
      <div class="max-w-3xl">
        <h2 class="text-3xl font-extrabold tracking-[-0.06em] text-[#111714] md:text-4xl">
          Migrar de LogiCommerce a Shopify: ecosistema y crecimiento
        </h2>
        <div class="mt-6 space-y-4 text-lg leading-8 text-[#617069]">
          <p>
            <a href="https://www.logicommerce.com/" target="_blank" rel="noopener" class="font-medium text-[#376A21] underline decoration-[#376A21]/30 hover:decoration-[#376A21]">LogiCommerce</a> es una plataforma que funciona bien en su ámbito, pero <strong class="text-[#111714]">Shopify ofrece un ecosistema y una velocidad de innovación que son difíciles de igualar</strong>: más de 8.000 apps verificadas en la <a href="https://apps.shopify.com/" target="_blank" rel="noopener" class="font-medium text-[#376A21] underline decoration-[#376A21]/30 hover:decoration-[#376A21]">Shopify App Store</a>, una comunidad global de desarrolladores, integraciones nativas con las principales herramientas de marketing, y funcionalidades que se actualizan continuamente sin intervención técnica.
          </p>
          <p>
            Si tu negocio necesita <a href="/soluciones/shopify-b2b/" class="font-medium text-[#376A21] underline decoration-[#376A21]/30 hover:decoration-[#376A21]">venta B2B</a>, <a href="/integracion-shopify/" class="font-medium text-[#376A21] underline decoration-[#376A21]/30 hover:decoration-[#376A21]">integraciones avanzadas</a> o simplemente más opciones para crecer, Shopify amplía significativamente las posibilidades respecto a LogiCommerce.
          </p>
        </div>
      </div>
    </div>
  </section>

  <ForWhomTable
    suitable={[
      'Empresas en LogiCommerce que necesitan más apps, integraciones o personalización.',
      'Negocios que quieren aprovechar funcionalidades como B2B nativo o checkout optimizado.',
      'Tiendas que buscan un ecosistema de partners y desarrolladores más amplio.',
      'Empresas que necesitan integrar su eCommerce con ERPs u otros sistemas empresariales.',
    ]}
    notSuitable={[
      'Negocios satisfechos con LogiCommerce y sin necesidad de funcionalidades adicionales.',
      'Empresas con contratos a largo plazo con LogiCommerce sin posibilidad de cambio.',
      'Tiendas con funcionalidades muy específicas de LogiCommerce sin equivalente en Shopify.',
    ]}
  />

  <Methodology
    title="Cómo migramos desde LogiCommerce"
    steps={[
      { step: '01', title: 'Auditoría', text: 'Analizamos tu instalación LogiCommerce: catálogo, estructura de datos, integraciones existentes y SEO actual.' },
      { step: '02', title: 'Mapeo y planificación', text: 'Definimos la correspondencia entre el modelo de datos de LogiCommerce y Shopify, el plan de redirecciones y la estrategia de migración.' },
      { step: '03', title: 'Migración y desarrollo', text: 'Transferimos datos, desarrollamos la nueva tienda y configuramos las integraciones necesarias.' },
      { step: '04', title: 'Validación y lanzamiento', text: 'Testamos datos migrados, flujos de compra y redirecciones. Lanzamos con monitorización activa.' },
    ]}
  />

  <FAQAccordion items={faqs} />

  <ContactBlock
    title="¿Considerando migrar de LogiCommerce a Shopify?"
    subtitle="Analizamos tu tienda LogiCommerce y te proponemos un plan de migración adaptado a tu operación."
    ctaPrimary={{ label: 'Consultar migración', href: '#contacto' }}
  />
</LandingLayout>
