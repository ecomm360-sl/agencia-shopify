---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEOHead from '../components/seo/SEOHead.astro';
---

<BaseLayout>
  <Fragment slot="head">
    <SEOHead
      title="Página no encontrada"
      description="La página que buscas no existe o ha sido movida. Visita nuestra home o explora nuestros servicios Shopify."
      noindex={true}
    />
  </Fragment>

  <section class="flex min-h-[60vh] items-center justify-center pt-32 pb-20">
    <div class="container text-center">
      <div class="text-8xl font-extrabold tracking-[-0.06em] text-[#7ECF4D]/20 md:text-[12rem]">404</div>
      <h1 class="mt-4 text-3xl font-extrabold tracking-[-0.04em] text-[#111714] md:text-4xl">
        Página no encontrada
      </h1>
      <p class="mt-4 max-w-md mx-auto text-lg text-[#617069]">
        La página que buscas no existe o ha sido movida. Puedes volver al inicio o explorar nuestros servicios.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/" class="inline-flex items-center rounded-full bg-[#7ECF4D] px-7 py-3.5 text-base font-semibold text-[#08110D] shadow-[0_16px_40px_rgba(126,207,77,0.34)] transition hover:bg-[#95D66A]">
          Ir al inicio
        </a>
        <a href="/shopify/" class="inline-flex rounded-full border border-[#d7e5d3] bg-white px-7 py-3.5 text-base font-medium text-[#376A21] transition hover:bg-[#f6faf4]">
          Ver servicios Shopify
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
