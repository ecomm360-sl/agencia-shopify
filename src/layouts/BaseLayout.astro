---
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';
import '../styles/global.css';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<!doctype html>
<html lang="es" dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Favicon & App -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#7ECF4D" />
    <meta name="msapplication-TileColor" content="#071311" />

    <!-- Self-hosted Fonts (eliminates Google Fonts waterfall: -5.7s FCP) -->
    <link rel="preload" href="/fonts/manrope-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/instrument-sans-latin.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Author & Geo -->
    <meta name="author" content="eComm360" />
    <meta name="geo.region" content="ES" />
    <meta name="geo.placename" content="España" />
    <link rel="author" href="/humans.txt" />

    <!-- Google Analytics (GA4) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-PCL0Y91VKM" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-PCL0Y91VKM');
    </script>

    <!-- SEO head slot (title, meta, OG, JSON-LD per page) -->
    <slot name="head" />
  </head>
  <body class:list={["min-h-screen bg-background text-foreground", className]}>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:rounded-lg focus:bg-[#7ECF4D] focus:px-4 focus:py-2 focus:text-[#08110D] focus:font-semibold">
      Saltar al contenido
    </a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
