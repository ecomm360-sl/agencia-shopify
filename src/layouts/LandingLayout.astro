---
import BaseLayout from './BaseLayout.astro';
import SEOHead from '../components/seo/SEOHead.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import Breadcrumbs, { type BreadcrumbItem } from '../components/global/Breadcrumbs.astro';
import { clusterLinks, type InternalLink } from '../data/internal-links';
import { speakableSpec, contactPage, SITE_URL, CURRENT_DATE } from '../data/structured-data';

interface Props {
  title: string;
  description: string;
  breadcrumbs: BreadcrumbItem[];
  jsonLd?: Record<string, unknown>[];
  ogImage?: string;
  ogTitle?: string;
  ogDescription?: string;
  keywords?: string;
}

const { title, description, breadcrumbs, jsonLd = [], ogImage, ogTitle, ogDescription, keywords } = Astro.props;

const currentPath = Astro.url.pathname;
const relatedPages: InternalLink[] = clusterLinks[currentPath] || [];

// Page-level WebPage schema with speakable + dateModified
const webPage = {
  ...speakableSpec,
  url: new URL(currentPath, SITE_URL).href,
  name: title,
  description,
  dateModified: CURRENT_DATE,
};

// Combine page-specific jsonLd with universal schemas (speakable + ContactPage)
const allJsonLd = [...jsonLd, webPage, contactPage];
---

<BaseLayout>
  <Fragment slot="head">
    <SEOHead title={title} description={description} ogImage={ogImage} ogTitle={ogTitle} ogDescription={ogDescription} keywords={keywords} />
    <JsonLd data={allJsonLd} />
  </Fragment>

  <div class="pt-24">
    <Breadcrumbs items={breadcrumbs} />
  </div>

  <article>
    <slot />
  </article>

  {relatedPages.length > 0 && (
    <aside class="bg-[#f3f7f0] py-16 md:py-20">
      <div class="container">
        <h2 class="text-2xl font-bold tracking-[-0.04em] text-[#111714] md:text-3xl">
          Páginas relacionadas
        </h2>
        <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {relatedPages.slice(0, 6).map((link) => (
            <a
              href={link.href}
              class="group rounded-2xl bg-white p-6 shadow-[0_12px_30px_rgba(17,23,20,0.06)] ring-1 ring-black/5 transition hover:-translate-y-0.5 hover:shadow-[0_18px_50px_rgba(17,23,20,0.1)]"
            >
              <h3 class="text-lg font-bold tracking-[-0.03em] text-[#111714] group-hover:text-[#376A21]">
                {link.label}
              </h3>
              <p class="mt-2 text-sm leading-6 text-[#617069]">{link.description}</p>
              <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-[#376A21]">
                Ver más
                <svg class="h-4 w-4 transition group-hover:translate-x-1" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
                </svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    </aside>
  )}
</BaseLayout>
