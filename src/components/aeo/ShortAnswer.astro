---
interface Props {
  text: string;
}

const { text } = Astro.props;
---

<section id="respuesta" class="bg-white py-12 md:py-16">
  <div class="container">
    <div class="max-w-3xl rounded-2xl border-l-4 border-[#7ECF4D] bg-[#f8fbf6] p-6 md:p-8">
      <p class="text-lg leading-8 text-[#24312b] md:text-xl">
        {text}
      </p>
    </div>
  </div>
</section>
