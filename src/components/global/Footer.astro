---
import Logo from './Logo.astro';
import { footerColumns } from '../../data/navigation';
---

<footer class="border-t border-black/5 bg-[#071311] pt-16 pb-8">
  <div class="container">
    <div class="grid gap-10 lg:grid-cols-[1.3fr_repeat(4,1fr)]">
      <!-- Brand column -->
      <div>
        <Logo variant="dark" />
        <p class="mt-4 max-w-xs text-sm leading-7 text-white/50">
          Partner tecnológico especializado en Shopify para diseño, migración, B2B, integración ERP y crecimiento en España.
        </p>
      </div>

      <!-- Link columns -->
      {footerColumns.map((column) => (
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-[0.2em] text-white/40">
            {column.title}
          </h3>
          <ul class="mt-4 space-y-3">
            {column.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-white/60 transition hover:text-white"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-14 flex flex-col items-center justify-between gap-4 border-t border-white/8 pt-8 md:flex-row">
      <p class="text-xs text-white/35">
        &copy; {new Date().getFullYear()} eComm360. Todos los derechos reservados.
      </p>
      <div class="flex gap-6 text-xs text-white/35">
        <a href="/aviso-legal/" class="transition hover:text-white/60">Aviso legal</a>
        <a href="/politica-privacidad/" class="transition hover:text-white/60">Política de privacidad</a>
        <a href="/cookies/" class="transition hover:text-white/60">Cookies</a>
      </div>
    </div>
  </div>
</footer>
