---
interface Props {
  text: string;
  tags: string[];
}

const { text, tags } = Astro.props;
---

<section class="border-y border-black/5 bg-[#f3f7f0] py-6">
  <div class="container">
    <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
      <p class="text-sm uppercase tracking-[0.28em] text-[#617069]">
        {text}
      </p>
      <div class="flex flex-wrap gap-x-8 gap-y-3 text-sm font-medium text-[#111714]">
        {tags.map((tag) => (
          <span>{tag}</span>
        ))}
      </div>
    </div>
  </div>
</section>
