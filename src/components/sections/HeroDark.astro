---
interface Metric {
  value: string;
  label: string;
}

interface Props {
  badge: string;
  title: string;
  titleAccent?: string;
  titleAfter?: string;
  subtitle: string;
  ctaPrimary?: { label: string; href: string };
  ctaSecondary?: { label: string; href: string };
  metrics?: Metric[];
  image?: { src: string; alt: string };
}

const {
  badge,
  title,
  titleAccent,
  titleAfter,
  subtitle,
  ctaPrimary,
  ctaSecondary,
  metrics = [],
  image,
} = Astro.props;
---

<section class="relative overflow-hidden bg-[#071311] pb-20 pt-32 md:pb-24 md:pt-36 lg:pb-28">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(126,207,77,0.12),transparent_30%),radial-gradient(circle_at_80%_20%,rgba(126,207,77,0.14),transparent_22%),linear-gradient(180deg,rgba(8,18,16,0.25),rgba(7,19,17,0.9))]"></div>
  <div class="absolute inset-0 opacity-40" style="background-image: linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 72px 72px;"></div>

  <div class="container relative z-10">
    <div class:list={["grid items-center gap-12", image ? "lg:grid-cols-[1.02fr_0.98fr] lg:gap-8" : ""]}>
      <div class="max-w-3xl">
        <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-white/12 bg-white/6 px-4 py-2 text-sm text-white/75 backdrop-blur-xl">
          <svg class="h-4 w-4 text-[#7ECF4D]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/><path d="M20 3v4"/><path d="M22 5h-4"/></svg>
          {badge}
        </div>

        <h1 class="max-w-4xl text-balance text-5xl font-extrabold leading-[0.92] tracking-[-0.07em] text-white sm:text-6xl lg:text-7xl xl:text-[5.8rem]">
          {title}{titleAccent && <span class="text-[#A7EA7A]">{` ${titleAccent}`}</span>}{titleAfter && (<><br />{titleAfter}</>)}
        </h1>

        <p class="mt-7 max-w-2xl text-lg leading-8 text-white/70 md:text-xl">
          {subtitle}
        </p>

        {(ctaPrimary || ctaSecondary) && (
          <div class="mt-10 flex flex-col items-start gap-4 sm:flex-row sm:items-center">
            {ctaPrimary && (
              <a href={ctaPrimary.href} class="group inline-flex items-center rounded-full bg-[#7ECF4D] px-7 py-3.5 text-base font-semibold text-[#08110D] shadow-[0_16px_40px_rgba(126,207,77,0.34)] transition hover:bg-[#95D66A]">
                {ctaPrimary.label}
                <svg class="ml-2 h-4 w-4 transition group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            )}
            {ctaSecondary && (
              <a href={ctaSecondary.href} class="inline-flex rounded-full border border-white/14 bg-white/5 px-7 py-3.5 text-base text-white transition hover:bg-white/10 hover:text-white">
                {ctaSecondary.label}
              </a>
            )}
          </div>
        )}

        {metrics.length > 0 && (
          <div class="mt-12 grid gap-4 md:grid-cols-3">
            {metrics.map((metric) => (
              <div class="rounded-3xl border border-white/10 bg-white/6 p-5 shadow-[0_12px_40px_rgba(0,0,0,0.18)] backdrop-blur-lg">
                <div class="text-lg font-bold tracking-[-0.04em] text-white">{metric.value}</div>
                <div class="mt-2 text-sm leading-6 text-white/62">{metric.label}</div>
              </div>
            ))}
          </div>
        )}
      </div>

      {image && (
        <div class="relative lg:pl-6">
          <div class="absolute -left-14 top-10 hidden h-28 w-28 rounded-full bg-[#7ECF4D]/18 blur-3xl lg:block"></div>
          <div class="absolute right-10 top-0 hidden h-24 w-24 rounded-full bg-emerald-300/12 blur-3xl lg:block"></div>
          <div class="relative overflow-hidden rounded-[2rem] border border-white/10 bg-white/5 p-3 shadow-[0_30px_120px_rgba(0,0,0,0.42)] backdrop-blur-xl">
            <img
              src={image.src}
              alt={image.alt}
              class="h-full w-full rounded-[1.5rem] object-cover"
              width="640"
              height="480"
              loading="eager"
            />
          </div>
          <div class="absolute -bottom-6 -left-3 max-w-[260px] rounded-[1.6rem] border border-white/10 bg-[rgba(243,247,240,0.08)] p-4 shadow-[0_20px_60px_rgba(0,0,0,0.36)] backdrop-blur-xl md:-left-8 md:max-w-[300px]">
            <div class="flex items-start gap-3">
              <div class="rounded-2xl bg-[#7ECF4D]/18 p-2 text-[#A7EA7A]">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v16a2 2 0 0 0 2 2h16"/><path d="m19 9-5 5-4-4-3 3"/></svg>
              </div>
              <div>
                <div class="text-sm font-semibold text-white">Diseño con lógica de plataforma</div>
                <div class="mt-1 text-sm leading-6 text-white/62">
                  Más claridad visual, mejor lectura comercial y una presencia más sólida desde el primer impacto.
                </div>
              </div>
            </div>
          </div>
        </div>
      )}
    </div>
  </div>
</section>
