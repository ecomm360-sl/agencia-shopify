---
interface Props {
  variant?: 'primary' | 'outline' | 'ghost';
  size?: 'default' | 'lg';
  href?: string;
  class?: string;
}

const { variant = 'primary', size = 'default', href, class: className } = Astro.props;

const baseClasses = 'inline-flex items-center justify-center font-semibold transition rounded-full';

const variantClasses = {
  primary: 'bg-[#7ECF4D] text-[#08110D] shadow-[0_12px_30px_rgba(126,207,77,0.35)] hover:bg-[#95D66A]',
  outline: 'border border-white/15 bg-white/5 text-white hover:bg-white/10 hover:text-white',
  ghost: 'text-[#376A21] hover:bg-[#eff8ea]',
};

const sizeClasses = {
  default: 'px-5 py-2.5 text-sm',
  lg: 'px-7 py-3.5 text-base',
};

const classes = [baseClasses, variantClasses[variant], sizeClasses[size], className].filter(Boolean).join(' ');

const Tag = href ? 'a' : 'button';
---

{href ? (
  <a href={href} class={classes}>
    <slot />
  </a>
) : (
  <button class={classes}>
    <slot />
  </button>
)}
