---
import { SITE_URL } from '../../data/structured-data';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogType?: string;
  keywords?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  canonical = new URL(Astro.url.pathname, SITE_URL).href,
  ogImage = `${SITE_URL}/og/home.png`,
  ogTitle,
  ogDescription,
  ogType = 'website',
  keywords,
  noindex = false,
} = Astro.props;

const fullTitle = title.includes('eComm360') ? title : `${title} | eComm360`;
const socialTitle = ogTitle || fullTitle;
const socialDescription = ogDescription || description;
---

<!-- Primary Meta -->
<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large, max-snippet:-1"} />
{keywords && <meta name="keywords" content={keywords} />}

<!-- Language -->
<meta property="og:locale" content="es_ES" />
<link rel="alternate" hreflang="es" href={canonical} />
<link rel="alternate" hreflang="x-default" href={canonical} />

<!-- Open Graph -->
<meta property="og:type" content={ogType} />
<meta property="og:title" content={socialTitle} />
<meta property="og:description" content={socialDescription} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={socialTitle} />
<meta property="og:site_name" content="eComm360 — Agencia Shopify" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={socialTitle} />
<meta name="twitter:description" content={socialDescription} />
<meta name="twitter:image" content={ogImage} />
